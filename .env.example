# ─── Supabase (client-side, préfixe VITE_) ───────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── OpenAI (server-side ONLY, PAS de préfixe VITE_) ────────
# Utilisée par l'API route /api/openai — jamais envoyée au navigateur
OPENAI_API_KEY=sk-your_openai_key_here
