{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "birthDate": { "type": "string" },
        "level": { "type": "string", "enum": ["Débutant", "Intermédiaire", "Avancé"] },
        "vma": { "type": "number" },
        "activeProgramId": { "type": "string" },
        "hasOnboarded": { "type": "boolean" },
        "isPaid": { "type": "boolean" }
      },
      "required": ["email"]
    },
    "Program": {
      "title": "Program",
      "description": "Running program details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "distance": { "type": "string" },
        "level": { "type": "string" },
        "raceName": { "type": "string" },
        "raceDate": { "type": "string" },
        "startDate": { "type": "string" },
        "trainingDays": { "type": "array" },
        "sessionsPerWeek": { "type": "number" },
        "timeObjective": { "type": "string" },
        "vma": { "type": "number" },
        "weeks": { "type": "string", "description": "JSON stringified weeks data" },
        "totalWeeks": { "type": "number" },
        "archivedDate": { "type": "string" },
        "raceInfo": { "type": "string", "description": "JSON stringified race info" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "users/{userId}/programs/{programId}": {
      "schema": "Program",
      "description": "User programs (active and history)"
    }
  }
}
